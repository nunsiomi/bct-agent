# ----------------------------------------------------------------------------
# BCT Agent -- environment variables.
# Copy this file to `.env` (gitignored) and fill in the values you actually use.
# ----------------------------------------------------------------------------

# --- LLM provider selection ----
# Set LLM_PROVIDER to ONE of:
#   anthropic            (default; uses ANTHROPIC_API_KEY)
#   openai_compatible    (Groq / Together / Fireworks / Ollama / vLLM)
LLM_PROVIDER=anthropic

# --- Anthropic (default path) ----
ANTHROPIC_API_KEY=your_anthropic_key_here
# LLM_MODEL=claude-sonnet-4-20250514

# --- Groq / Together / OpenAI-compatible path ----
# To use Groq instead of Anthropic, switch the four lines below in:
#   LLM_PROVIDER=openai_compatible
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#   LLM_API_KEY_ENV=GROQ_API_KEY
# Then set GROQ_API_KEY=gsk_... (from https://console.groq.com/keys).
#
# Together AI:
#   LLM_BASE_URL=https://api.together.xyz/v1
#   LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   LLM_API_KEY_ENV=TOGETHER_API_KEY
GROQ_API_KEY=
TOGETHER_API_KEY=

# --- Embeddings (Phase 4 hybrid retriever) ----
# tfidf is the default; sentence_transformer requires `pip install sentence-transformers`.
EMBEDDING_BACKEND=tfidf
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
